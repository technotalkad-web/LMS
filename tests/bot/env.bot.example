# ─────────────────────────────────────────────────────────────────────────
# LMS Testing Bot — environment template
#
# Copy the values you need into `.env.test.local` at the repo root (gitignored).
# The bot and the e2e suite share these vars.
#
# CRITICAL: every value below must point at STAGING, never production.
# global-setup hard-blocks production-shaped URLs.
# ─────────────────────────────────────────────────────────────────────────

# The deployed staging URL the bot drives (Cloudflare preview/staging).
E2E_BASE_URL=https://staging.your-lms.example.com

# STAGING Supabase project (NOT production).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-STAGING-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_STAGING_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_STAGING_SERVICE_ROLE_KEY

# Optional — only if you want the bot to also positively exercise cron auth.
# CRON_SECRET=your-staging-cron-secret

# ── Bot knobs (all optional) ──────────────────────────────────────────────
# BOT_WORKERS=2          # parallel workers (keep staging load civil)
# BOT_KEEP_DATA=1        # don't purge the seeded world after the run
# BOT_REPORT_DIR=./bot-report   # where reports are written
# E2E_ALLOW_PROD=1       # DANGER: override the production guard (don't)
